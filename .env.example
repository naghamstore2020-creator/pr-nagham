# Database Connection (Prisma & general PG)
DATABASE_URL="postgresql://postgres:password@db.supabase.co:5432/postgres"

# NextAuth Configuration
AUTH_SECRET="any-32-chars-long-secret-key-goes-here"

# Supabase API Settings
NEXT_PUBLIC_SUPABASE_URL="https://your-supabase-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-bypass-rls"

# Fallback Local Credentials (Optional for local development / backup)
ADMIN_FALLBACK_PASS="admin123"
DEMO_FALLBACK_PASS="demo123"
EDITOR_FALLBACK_PASS="editor123"
